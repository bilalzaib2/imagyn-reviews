{{ 'imagyn-tokens.css' | asset_url | stylesheet_tag }}
{{ 'imagyn-typography.css' | asset_url | stylesheet_tag }}
{{ 'imagyn-component-badge.css' | asset_url | stylesheet_tag }}
{{ 'collection-rating-badges.css' | asset_url | stylesheet_tag }}
{{ 'imagyn-appearance.js' | asset_url | script_tag }}
<script
  src="{{ 'collection-rating-badges.js' | asset_url }}"
  data-imagyn-collection-badges
  data-star-color="{{ block.settings.star_color }}"
  data-text-color="{{ block.settings.text_color }}"
  defer
></script>

{% schema %}
{
  "name": "Collection Ratings",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Adds a small rating badge to product cards in collection grids, search results, and featured/related product sections. Enable once here — no per-page placement needed."
    },
    { "type": "color", "id": "star_color", "label": "Star color" },
    { "type": "color", "id": "text_color", "label": "Text color" }
  ]
}
{% endschema %}
