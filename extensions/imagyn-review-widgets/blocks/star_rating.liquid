{% comment %}
  Rendered here (inside the product info column) only until reviews-widget.js's init()
  relocates the whole .imagyn-ratings-section node to sit as a sibling after the enclosing
  Shopify section — see the "Full-width section relocation" note in
  docs/STOREFRONT_DESIGN_SYSTEM.md. If that relocation can't find a suitable ancestor (a
  non-standard theme), this stays right here and still works, just narrower.
{% endcomment %}
<div class="imagyn-ratings-section" data-imagyn-ratings-section>
  <div class="imagyn-ratings-section__inner">
    <h2 class="imagyn-ratings-section__heading">{{ block.settings.section_heading | default: "Ratings & Reviews" }}</h2>

    <div
      class="imagyn-reviews"
      data-imagyn-reviews
      data-product-id="{{ product.id }}"
      data-show-average-rating="{{ block.settings.show_average_rating }}"
      data-show-review-count="{{ block.settings.show_review_count }}"
      data-show-write-review-button="{{ block.settings.show_write_review_button }}"
      data-reviews-per-page="{{ block.settings.reviews_per_page }}"
      data-star-color="{{ block.settings.star_color }}"
      data-button-color="{{ block.settings.button_color }}"
      data-background-color="{{ block.settings.background_color }}"
      data-border-color="{{ block.settings.border_color }}"
      data-border-radius="{{ block.settings.border_radius }}"
      data-heading-font-size="{{ block.settings.heading_size }}"
      data-body-font-size="{{ block.settings.body_size }}"
      data-layout="{{ block.settings.layout }}"
      data-show-load-more-button="{{ block.settings.show_load_more_button }}"
    >
      <div data-imagyn-summary></div>
      <div data-imagyn-attributes></div>
      <div data-imagyn-gallery></div>
      <div data-imagyn-sort></div>
      <div class="imagyn-reviews__results" data-imagyn-list>
        <p class="imagyn-reviews__loading">Loading reviews…</p>
      </div>
      <div class="imagyn-reviews__write" data-imagyn-write></div>
    </div>
  </div>
</div>

{% comment %}
  Server-rendered JSON-LD (app/services/structuredData/) — written to this metafield by
  syncProductStructuredData whenever a product's approved review data changes (see
  app/routes/app.reviews.tsx and app.reviews.$id.edit.tsx). Read directly here with zero
  extra request, so search engines see it in the initial page HTML rather than depending
  on JS execution. Guarding on `.value` (not just the metafield's presence) means a
  product with zero approved reviews — whose synced value is the JSON literal `null` —
  correctly renders no tag at all, matching Google's requirement that a Product node
  carry real review/aggregateRating data or not exist.

  NOTE ON SYNTAX: bracket notation with the literal "$app" reserved-namespace string
  (product.metafields["$app"].key) — NOT the dot-notation product.metafields.app.key
  shown in Shopify's general metafields docs. Verified empirically: dot-notation silently
  resolves to nothing inside a theme app extension block, even in a fully deployed app
  version; Shopify's theme-app-extension-specific configuration docs confirm bracket
  notation is the actual required form here.
{% endcomment %}
{% if block.settings.show_structured_data and product.metafields["$app"].reviews_jsonld.value %}
  <script type="application/ld+json">{{ product.metafields["$app"].reviews_jsonld.value | json }}</script>
{% endif %}

