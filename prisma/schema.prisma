// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified      Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  domain       String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  products     Product[]
  reviews      Review[]
  reviewRequests ReviewRequest[]
  widgets      Widget[]
  appearances  Appearance[]
}

model Product {
  id               String   @id @default(cuid())

  storeId          String
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  shopifyProductId String? @unique
  name             String
  handle           String?
  vendor           String?
  productType      String?
  status           String?
  featuredImage    String?
  slug             String?
  description      String?

  // Denormalized review statistics, recalculated by review.server.ts after every review mutation.
  averageRating    Float    @default(0)
  totalReviews     Int      @default(0)
  rating5Count     Int      @default(0)
  rating4Count     Int      @default(0)
  rating3Count     Int      @default(0)
  rating2Count     Int      @default(0)
  rating1Count     Int      @default(0)

  // Set only by product.server.ts's syncProducts, kept separate from updatedAt so review-stat
  // recalculation (which also touches this row) can't make "last synced" look fresher than it is.
  lastSyncedAt     DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reviews          Review[]
  reviewRequests   ReviewRequest[]
  widgets          Widget[]
  aiSummary        ProductAiSummary?
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id               String       @id @default(cuid())

  storeId          String
  store            Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productTitle     String?

  rating           Int
  title            String?
  content          String

  reviewerName     String
  reviewerEmail    String?
  reviewerLocation String?
  verifiedPurchase Boolean      @default(false)

  status           ReviewStatus @default(PENDING)
  isPublished      Boolean      @default(false)
  helpfulCount     Int          @default(0)
  notHelpfulCount  Int          @default(0)
  featured         Boolean      @default(false)

  reply            String?
  repliedAt        DateTime?

  photoUrls        String?
  deletedAt        DateTime?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  helpfulVotes     ReviewHelpfulVote[]
  media            ReviewMedia[]

  @@index([deletedAt, createdAt])
  @@index([storeId, deletedAt, createdAt])
  @@index([productId, deletedAt])
  @@index([status])
  @@index([rating])
  @@index([verifiedPurchase])
  @@index([featured])
  @@index([helpfulCount])
}

enum ReviewMediaType {
  IMAGE
  VIDEO
}

// Customer-uploaded photos (and, later, videos — the type column and enum already support
// VIDEO so that can be turned on without a schema change) attached to a review. One row per
// asset rather than a delimited string (contrast the older, unused Review.photoUrls) so each
// item carries its own moderation lifecycle (independently deletable) and real dimensions for
// aspect-ratio-safe rendering, instead of just a bare URL.
model ReviewMedia {
  id           String          @id @default(cuid())

  reviewId     String
  review       Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  type         ReviewMediaType @default(IMAGE)
  url          String
  width        Int?
  height       Int?
  thumbnailUrl String?

  createdAt    DateTime        @default(now())

  @@index([reviewId])
}

enum HelpfulVoteValue {
  HELPFUL
  NOT_HELPFUL
}

// One row per (review, visitor) — the unique constraint is what makes "exactly one vote
// per visitor, can change their vote" an invariant enforced by the database itself, not
// just application logic. visitorId is an opaque string: a client-generated anonymous id
// for storefront shoppers (see reviews-widget.js) today, but nothing here assumes that —
// a real customer id would work identically, so this doesn't need to change if/when the
// storefront gains real customer auth.
model ReviewHelpfulVote {
  id         String           @id @default(cuid())

  reviewId   String
  review     Review           @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  visitorId  String
  vote       HelpfulVoteValue

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([reviewId, visitorId])
  @@index([reviewId, vote])
}

// One cached summary per product, generated from that product's APPROVED reviews by
// whichever AiProvider is currently configured (see app/services/ai/) — never generated
// on a storefront page view (see aiSummary.server.ts's getAiSummary, a pure cache read).
// positives/negatives are stored as JSON-encoded string arrays, the same pattern
// Widget.settings already uses for structured data in this schema.
model ProductAiSummary {
  id              String   @id @default(cuid())

  productId       String   @unique
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  summary         String
  positives       String
  negatives       String
  recommendation  String

  reviewCountUsed Int
  provider        String
  modelUsed       String

  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ReviewRequest {
  id           String          @id @default(cuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  email        String?
  name         String?
  orderNumber  String?
  customMessage String?
  requestToken String?         @unique
  // Extension seam for link security (README: expiration, single-use validation, fraud
  // protection) — a single opaque token + these two timestamps is enough for the MVP
  // resolver (app/routes/r.$token.tsx) to enforce both without a separate token table.
  // A dedicated ReviewRequestToken model only earns its keep once a request can have
  // *multiple* concurrent tokens (e.g. reminder emails each with their own link) — that's
  // explicitly future work, not this pass.
  tokenExpiresAt DateTime?
  tokenUsedAt    DateTime?
  delayDays    Int?
  scheduledFor DateTime?
  status       String          @default("pending")
  sentAt       DateTime?
  openedAt     DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Widget {
  id           String          @id @default(cuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  name         String
  type         String          @default("review")
  settings     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// The centralized, store-wide design-token system every storefront widget (Product
// Reviews, Product Rating Badge, Collection Rating Badge, and future ones) consumes —
// see app/services/appearance.shared.ts for the token contract and
// docs/STOREFRONT_DESIGN_SYSTEM.md for the underlying --imagyn-* CSS custom properties
// these tokens resolve onto. Deliberately store-wide (no productId), unlike Widget:
// the whole point is one shared source of truth, not per-widget-type duplication.
//
// Multiple rows per store are allowed (only one isActive) rather than a hard singleton,
// so "Saved Presets"/"Brand Themes" (both documented future work) are additive later —
// more rows, isActive toggled — with no schema change.
model Appearance {
  id           String          @id @default(cuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name         String          @default("Default")
  // "minimal" | "modern" | "editorial" | "classic" | "custom" — see
  // app/services/appearance.presets.ts. Only "custom" is functional today.
  preset       String          @default("custom")
  // Exactly one true per store; enforced in appearance.server.ts (not a DB constraint —
  // see that file for why), same application-level-enforcement convention already used
  // for widget resolution in widget.server.ts.
  isActive     Boolean         @default(true)

  // JSON-encoded AppearanceTokens (appearance.shared.ts) — same JSON-as-String precedent
  // as Widget.settings, so the token contract can grow without a migration per field.
  tokens       String

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([storeId, isActive])
}
