// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified      Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  domain       String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  products     Product[]
  reviews      Review[]
  reviewRequests ReviewRequest[]
  widgets      Widget[]
}

model Product {
  id               String   @id @default(cuid())

  storeId          String
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  shopifyProductId String? @unique
  name             String
  handle           String?
  vendor           String?
  productType      String?
  status           String?
  featuredImage    String?
  slug             String?
  description      String?

  // Denormalized review statistics, recalculated by review.server.ts after every review mutation.
  averageRating    Float    @default(0)
  totalReviews     Int      @default(0)
  rating5Count     Int      @default(0)
  rating4Count     Int      @default(0)
  rating3Count     Int      @default(0)
  rating2Count     Int      @default(0)
  rating1Count     Int      @default(0)

  // Set only by product.server.ts's syncProducts, kept separate from updatedAt so review-stat
  // recalculation (which also touches this row) can't make "last synced" look fresher than it is.
  lastSyncedAt     DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reviews          Review[]
  reviewRequests   ReviewRequest[]
  widgets          Widget[]
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id               String       @id @default(cuid())

  storeId          String
  store            Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating           Int
  title            String?
  content          String

  reviewerName     String
  reviewerEmail    String?
  reviewerLocation String?
  verifiedPurchase Boolean      @default(false)

  status           ReviewStatus @default(PENDING)
  isPublished      Boolean      @default(false)
  helpfulCount     Int          @default(0)
  featured         Boolean      @default(false)

  reply            String?
  repliedAt        DateTime?

  photoUrls        String?
  deletedAt        DateTime?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([deletedAt, createdAt])
  @@index([storeId, deletedAt, createdAt])
  @@index([productId, deletedAt])
  @@index([status])
  @@index([rating])
  @@index([verifiedPurchase])
  @@index([featured])
}

model ReviewRequest {
  id           String          @id @default(cuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  email        String?
  name         String?
  orderNumber  String?
  customMessage String?
  requestToken String?
  delayDays    Int?
  scheduledFor DateTime?
  status       String          @default("pending")
  sentAt       DateTime?
  openedAt     DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Widget {
  id           String          @id @default(cuid())
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  name         String
  type         String          @default("review")
  settings     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}
